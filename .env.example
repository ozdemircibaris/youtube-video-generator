# AWS Polly Configuration for Text-to-Speech
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Azure OpenAI Configuration for Translations
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2023-05-15
AZURE_OPENAI_COMPLETION_DEPLOYMENT=gpt-35-turbo

# YouTube API credentials for video upload
# Should be a JSON string of your client_secrets.json file
YOUTUBE_API_CREDENTIALS=